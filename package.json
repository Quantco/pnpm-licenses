{
  "name": "@quantco/pnpm-licenses",
  "version": "2.4.2",
  "description": "Generate third party license disclaimers in pnpm-based projects",
  "homepage": "https://github.com/Quantco/pnpm-licenses",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Quantco/pnpm-licenses.git"
  },
  "bugs": {
    "url": "https://github.com/Quantco/pnpm-licenses/issues"
  },
  "files": [
    "dist",
    "LICENSE",
    "readme.md"
  ],
  "main": "dist/api.mjs",
  "types": "dist/api.d.mts",
  "bin": {
    "pnpm-licenses": "dist/index.mjs"
  },
  "keywords": [
    "spdx",
    "license",
    "pnpm",
    "cli"
  ],
  "author": "Janina Wibker",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint ./src --ext ts"
  },
  "dependencies": {
    "minimist": "^1.2.8",
    "multimatch": "^8.0.0",
    "remove-markdown": "^0.5.5",
    "spdx-license-list": "^6.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.3.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.5.0"
}
